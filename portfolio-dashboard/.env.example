# ----------------------------------------------------------------------------
# Portfolio Dashboard environment variables
# Copy this file to ".env" and fill in the real values. Never commit ".env".
# ----------------------------------------------------------------------------

# Neon Postgres connection string (same value used by the Frontend app).
# From the Neon dashboard -> Connection Details -> "Prisma" or "psql" string.
# Make sure it ends with ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign login session tokens (JWT). Use a long random string.
# Generate one with:  openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# Cloudinary credentials (Dashboard -> Settings -> API Keys).
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# First admin account created by the seed script.
SEED_ADMIN_EMAIL="addenajmalkhanpk@gmail.com"
SEED_ADMIN_PASSWORD="change-this-strong-password"
SEED_ADMIN_NAME="Adden Ajmal Khan"

# OPTIONAL: restrict which emails can be added as dashboard users.
# Leave BOTH blank to allow any validly-formatted email.
#   ALLOWED_EMAIL_DOMAINS — comma-separated domains, e.g. "gmail.com,unsj-cuim.edu.ar"
#   ALLOWED_EMAILS        — comma-separated exact addresses, e.g. "a@x.com,b@y.com"
ALLOWED_EMAIL_DOMAINS=""
ALLOWED_EMAILS=""
